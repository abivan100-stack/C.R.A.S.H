# Copy this file to ".env" and paste your MongoDB Atlas connection string below.
# The real .env is gitignored and must NEVER be committed.
#
# Example shape (do not commit a real one):
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# C.R.A.S.H Bot — Anthropic API key for the /ask endpoint. Read from the environment
# only (os.environ), never hardcoded. Locally: paste your key after the "=" below.
# In production (Render): set ANTHROPIC_API_KEY in the service's Environment settings.
ANTHROPIC_API_KEY=

